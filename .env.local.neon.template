# =============================================
# KONFIGURASI UNTUK NEON TECH
# Copy file ini ke .env.local dan isi dengan nilai Anda
# =============================================

# Database Neon (PostgreSQL)
NEXT_PUBLIC_NEON_DATABASE_URL="postgresql://user:password@host/database_name?sslmode=require"

# JWT Secret untuk auth custom
NEXT_PUBLIC_JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Admin Emails (comma-separated)
NEXT_PUBLIC_ADMIN_EMAILS="kancahate.official@gmail.com,lenterabatin.id@gmail.com"

# Anthropic API (untuk AI)
NEXT_PUBLIC_ANTHROPIC_API_KEY="your-anthropic-api-key"
NEXT_PUBLIC_ANTHROPIC_BASE_URL="https://api.anthropic.com"

# Gemini API (untuk AI)
NEXT_PUBLIC_GEMINI_API_KEY="your-gemini-api-key"

# App Configuration
NEXT_PUBLIC_APP_NAME="Kancah Ate"
NEXT_PUBLIC_APP_URL="kancahate.my.id,http://localhost:3000"

# Vercel (Opsional jika deploy ke Vercel)
VERCEL_OIDC_TOKEN="your-vercel-oidc-token"
